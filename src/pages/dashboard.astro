---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard – Rocky Ocean</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F4F5F7;
      --card: #FFFFFF;
      --ink: #1A2332;
      --ink-muted: #5A6472;
      --accent: #2B7FCC;
      --accent-dim: #EBF4FF;
      --border: #E2E4E0;
      --sidebar: #1A2332;
      --sidebar-text: rgba(250,250,247,0.65);
      --sidebar-active: #2B7FCC;
      --green: #2D9B6F;
      --green-dim: #E8F7F1;
      --amber: #D97706;
      --amber-dim: #FEF3C7;
      --red: #DC2626;
      --red-dim: #FEE2E2;
      --font: 'Montserrat', system-ui, sans-serif;
    }

    html, body { height: 100%; }

    body {
      font-family: var(--font);
      font-size: 0.875rem;
      color: var(--ink);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
    }

    .layout {
      display: flex;
      height: 100vh;
      overflow: hidden;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: 220px;
      flex-shrink: 0;
      background: var(--sidebar);
      display: flex;
      flex-direction: column;
      padding: 0;
      overflow-y: auto;
    }

    .sidebar-header {
      padding: 1.5rem 1.25rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .sidebar-logo {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #FAFAF7;
    }

    .sidebar-subtitle {
      font-size: 0.65rem;
      color: var(--sidebar-text);
      margin-top: 0.2rem;
      letter-spacing: 0.05em;
    }

    .sidebar-nav {
      padding: 1rem 0;
      flex: 1;
    }

    .nav-label {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      padding: 0.75rem 1.25rem 0.4rem;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      padding: 0.6rem 1.25rem;
      cursor: pointer;
      color: var(--sidebar-text);
      font-size: 0.8rem;
      font-weight: 400;
      transition: background 0.15s, color 0.15s;
      border-left: 2px solid transparent;
      user-select: none;
    }

    .nav-item:hover { background: rgba(255,255,255,0.06); color: #fff; }

    .nav-item.active {
      color: #fff;
      background: rgba(43,127,204,0.18);
      border-left-color: var(--sidebar-active);
      font-weight: 500;
    }

    .nav-icon { font-size: 1rem; width: 1.2rem; text-align: center; }

    .sidebar-footer {
      padding: 1rem 1.25rem;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .sidebar-link {
      display: block;
      font-size: 0.7rem;
      color: var(--sidebar-text);
      text-decoration: none;
      padding: 0.3rem 0;
      transition: color 0.15s;
    }
    .sidebar-link:hover { color: #fff; }

    /* ── Main ── */
    .main {
      flex: 1;
      overflow-y: auto;
      padding: 2rem;
    }

    .section { display: none; }
    .section.active { display: block; }

    .section-title {
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      margin-bottom: 0.25rem;
    }

    .section-desc {
      font-size: 0.8rem;
      color: var(--ink-muted);
      margin-bottom: 1.75rem;
    }

    /* ── Cards ── */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem;
    }

    .card-title {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 0.75rem;
    }

    /* ── Stat Cards ── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .stat-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem;
    }

    .stat-label {
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 0.5rem;
    }

    .stat-value {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1;
    }

    .stat-sub {
      font-size: 0.72rem;
      color: var(--ink-muted);
      margin-top: 0.3rem;
    }

    /* ── Grid layouts ── */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }

    @media (max-width: 900px) {
      .two-col, .three-col { grid-template-columns: 1fr; }
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-family: var(--font);
      font-size: 0.78rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s;
      border: 1px solid transparent;
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }
    .btn-primary:hover { background: #1f6bb5; }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-ghost {
      background: transparent;
      color: var(--ink-muted);
      border-color: var(--border);
    }
    .btn-ghost:hover { background: var(--bg); color: var(--ink); }

    .btn-danger {
      background: transparent;
      color: var(--red);
      border-color: transparent;
    }
    .btn-danger:hover { background: var(--red-dim); }

    .btn-sm { padding: 0.3rem 0.65rem; font-size: 0.72rem; }

    /* ── Badges ── */
    .badge {
      display: inline-block;
      padding: 0.18rem 0.55rem;
      border-radius: 999px;
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .badge-planlagt { background: var(--amber-dim); color: var(--amber); }
    .badge-skrevet { background: var(--accent-dim); color: var(--accent); }
    .badge-publisert { background: var(--green-dim); color: var(--green); }

    /* ── Chips ── */
    .chips { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }

    .chip {
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      font-size: 0.75rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s;
      background: var(--card);
      color: var(--ink-muted);
      user-select: none;
    }
    .chip:hover { border-color: var(--accent); color: var(--accent); }
    .chip.selected { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* ── Form elements ── */
    input, textarea, select {
      width: 100%;
      font-family: var(--font);
      font-size: 0.82rem;
      color: var(--ink);
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.55rem 0.75rem;
      transition: border-color 0.15s;
      outline: none;
    }
    input:focus, textarea:focus, select:focus { border-color: var(--accent); background: #fff; }
    textarea { resize: vertical; }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.3rem; }
    .form-label { font-size: 0.72rem; font-weight: 500; color: var(--ink-muted); }

    /* ── Content plan list ── */
    .plan-list { display: flex; flex-direction: column; gap: 0.5rem; }

    .plan-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.85rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .plan-item-platform {
      font-size: 1.1rem;
      width: 1.5rem;
      text-align: center;
      flex-shrink: 0;
    }

    .plan-item-body { flex: 1; min-width: 0; }

    .plan-item-title {
      font-size: 0.83rem;
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .plan-item-meta {
      font-size: 0.7rem;
      color: var(--ink-muted);
      margin-top: 0.15rem;
    }

    .plan-item-actions { display: flex; gap: 0.25rem; flex-shrink: 0; }

    /* ── AI Output ── */
    .ai-output {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem;
      font-size: 0.82rem;
      line-height: 1.75;
      min-height: 120px;
      white-space: pre-wrap;
      font-family: var(--font);
      color: var(--ink);
    }

    .ai-output.loading { color: var(--ink-muted); font-style: italic; }
    .ai-output.empty { color: var(--ink-muted); }

    /* ── Media cards ── */
    .media-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .media-icon { font-size: 2rem; }
    .media-name { font-size: 0.9rem; font-weight: 600; }
    .media-handle { font-size: 0.75rem; color: var(--ink-muted); }

    /* ── Modal ── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 50;
      align-items: center;
      justify-content: center;
    }
    .modal-overlay.open { display: flex; }

    .modal {
      background: var(--card);
      border-radius: 12px;
      padding: 1.75rem;
      width: 100%;
      max-width: 480px;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .modal-title { font-size: 1rem; font-weight: 700; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 0.5rem; }

    /* ── Filter tabs ── */
    .filter-tabs { display: flex; gap: 0.25rem; margin-bottom: 1rem; }

    .filter-tab {
      padding: 0.35rem 0.8rem;
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 500;
      cursor: pointer;
      color: var(--ink-muted);
      border: 1px solid transparent;
      transition: all 0.15s;
      user-select: none;
    }
    .filter-tab:hover { background: var(--card); color: var(--ink); }
    .filter-tab.active { background: var(--card); color: var(--ink); border-color: var(--border); }

    /* ── Divider ── */
    .divider { border: none; border-top: 1px solid var(--border); margin: 1.25rem 0; }

    /* ── Empty state ── */
    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--ink-muted);
    }
    .empty-state p { font-size: 0.82rem; }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }
  </style>
</head>
<body>
<div class="layout">

  <!-- ── Sidebar ── -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">Rocky Ocean</div>
      <div class="sidebar-subtitle">NOR 11782 · Dashboard</div>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-label">Navigasjon</div>
      <div class="nav-item active" data-section="oversikt">
        <span class="nav-icon">⚓</span> Oversikt
      </div>
      <div class="nav-item" data-section="innholdsplan">
        <span class="nav-icon">📅</span> Innholdsplan
      </div>
      <div class="nav-item" data-section="ai">
        <span class="nav-icon">🤖</span> AI Assistent
      </div>
      <div class="nav-item" data-section="medier">
        <span class="nav-icon">📱</span> Medier & Kanaler
      </div>
    </nav>

    <div class="sidebar-footer">
      <a href="/" class="sidebar-link">← Tilbake til nettside</a>
      <a href="https://www.instagram.com/" target="_blank" class="sidebar-link">Instagram ↗</a>
    </div>
  </aside>

  <!-- ── Main content ── -->
  <main class="main">

    <!-- OVERSIKT -->
    <section id="oversikt" class="section active">
      <div class="section-title">Oversikt</div>
      <div class="section-desc">Status for Rocky Ocean på tvers av kanaler</div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Innlegg planlagt</div>
          <div class="stat-value" id="stat-planlagt">0</div>
          <div class="stat-sub">venter på publisering</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Publisert</div>
          <div class="stat-value" id="stat-publisert">0</div>
          <div class="stat-sub">totalt i innholdsplan</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Idéer lagret</div>
          <div class="stat-value" id="stat-ideer">0</div>
          <div class="stat-sub">fra AI og manuelt</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Nettside</div>
          <div class="stat-value" style="font-size:1.1rem;padding-top:0.3rem;">
            <a href="/" target="_blank" style="color:var(--accent);text-decoration:none;font-size:0.82rem;font-weight:600;">rocky-ocean.no ↗</a>
          </div>
          <div class="stat-sub">åpne i ny fane</div>
        </div>
      </div>

      <div class="two-col">
        <div class="card">
          <div class="card-title">Kommende innlegg</div>
          <div id="oversikt-upcoming" class="plan-list">
            <div class="empty-state"><p>Ingen innlegg planlagt ennå.<br>Gå til Innholdsplan for å legge til.</p></div>
          </div>
        </div>

        <div class="card">
          <div class="card-title">Hurtiglenker</div>
          <div style="display:flex;flex-direction:column;gap:0.5rem;margin-top:0.25rem;">
            <button class="btn btn-primary" onclick="navigate('ai')">🤖 Generer innholdsideer</button>
            <button class="btn btn-ghost" onclick="navigate('innholdsplan')">📅 Legg til i innholdsplan</button>
            <a href="https://www.instagram.com/" target="_blank" class="btn btn-ghost" style="text-decoration:none;justify-content:center;">📸 Åpne Instagram</a>
            <a href="https://analytics.google.com/" target="_blank" class="btn btn-ghost" style="text-decoration:none;justify-content:center;">📊 Google Analytics</a>
          </div>
        </div>
      </div>
    </section>

    <!-- INNHOLDSPLAN -->
    <section id="innholdsplan" class="section">
      <div class="section-title">Innholdsplan</div>
      <div class="section-desc">Planlegg og følg opp innlegg på tvers av plattformer</div>

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
        <div class="filter-tabs">
          <div class="filter-tab active" data-filter="alle">Alle</div>
          <div class="filter-tab" data-filter="planlagt">Planlagt</div>
          <div class="filter-tab" data-filter="skrevet">Skrevet</div>
          <div class="filter-tab" data-filter="publisert">Publisert</div>
        </div>
        <button class="btn btn-primary btn-sm" onclick="openAddModal()">+ Nytt innlegg</button>
      </div>

      <div id="plan-list" class="plan-list">
        <div class="empty-state"><p>Ingen innlegg ennå. Klikk «Nytt innlegg» for å starte.</p></div>
      </div>
    </section>

    <!-- AI ASSISTENT -->
    <section id="ai" class="section">
      <div class="section-title">AI Assistent</div>
      <div class="section-desc">Få kreative innholdsideer fra Claude tilpasset Rocky Ocean</div>

      <div class="card" style="margin-bottom:1rem;">
        <div class="card-title">Velg tema</div>
        <div class="chips" id="topic-chips">
          <div class="chip" data-topic="kappseiling">🏆 Kappseiling</div>
          <div class="chip" data-topic="vedlikehold">🔧 Vedlikehold</div>
          <div class="chip" data-topic="reise og langtur">⛵ Langtur</div>
          <div class="chip" data-topic="dekk og rigg">🪝 Dekk & rigg</div>
          <div class="chip" data-topic="livet til sjøs">🌊 Livet til sjøs</div>
          <div class="chip" data-topic="solnedgang og stemning">🌅 Stemning</div>
          <div class="chip" data-topic="båtsesongen åpner">🎉 Sesongstart</div>
          <div class="chip" data-topic="navigasjon og vær">🧭 Navigasjon</div>
        </div>

        <div class="form-group" style="margin-bottom:0.75rem;">
          <label class="form-label">Eget tema (valgfritt)</label>
          <input type="text" id="custom-topic" placeholder="F.eks. ny seil, racing-resultater, havneliv..." />
        </div>

        <div class="form-group" style="margin-bottom:1rem;">
          <label class="form-label">Ekstra kontekst (valgfritt)</label>
          <textarea id="extra-context" rows="2" placeholder="F.eks. vi vant regattaen i helgen, 12 knop vind, bilder av spinnaker..."></textarea>
        </div>

        <button class="btn btn-primary" id="generate-btn" onclick="generateIdeas()">✨ Generer ideer</button>
      </div>

      <div class="card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
          <div class="card-title" style="margin:0;">Forslag fra Claude</div>
          <button class="btn btn-ghost btn-sm" id="save-ideas-btn" style="display:none" onclick="saveIdeasToPlan()">💾 Lagre som idéer</button>
        </div>
        <div class="ai-output empty" id="ai-output">Velg et tema og klikk «Generer ideer» for å få forslag.</div>
      </div>
    </section>

    <!-- MEDIER -->
    <section id="medier" class="section">
      <div class="section-title">Medier & Kanaler</div>
      <div class="section-desc">Oversikt over Rocky Oceans tilstedeværelse på nett</div>

      <div class="three-col">
        <div class="media-card">
          <div class="media-icon">📸</div>
          <div>
            <div class="media-name">Instagram</div>
            <div class="media-handle">@rockyocean_nor</div>
          </div>
          <p style="font-size:0.78rem;color:var(--ink-muted);line-height:1.5;">
            Hovedkanal for bilder, stories og racing-oppdateringer.
          </p>
          <a href="https://www.instagram.com/" target="_blank" class="btn btn-primary btn-sm" style="text-decoration:none;width:fit-content;">
            Åpne Instagram ↗
          </a>
        </div>

        <div class="media-card">
          <div class="media-icon">🌐</div>
          <div>
            <div class="media-name">Nettside</div>
            <div class="media-handle">rocky-ocean.no</div>
          </div>
          <p style="font-size:0.78rem;color:var(--ink-muted);line-height:1.5;">
            Presentasjonsside med spesifikasjoner og galleri.
          </p>
          <a href="/" target="_blank" class="btn btn-ghost btn-sm" style="text-decoration:none;width:fit-content;">
            Se nettside ↗
          </a>
        </div>

        <div class="media-card">
          <div class="media-icon">📊</div>
          <div>
            <div class="media-name">Analytics</div>
            <div class="media-handle">Google Analytics</div>
          </div>
          <p style="font-size:0.78rem;color:var(--ink-muted);line-height:1.5;">
            Trafikk og besøksstatistikk for nettsiden.
          </p>
          <a href="https://analytics.google.com/" target="_blank" class="btn btn-ghost btn-sm" style="text-decoration:none;width:fit-content;">
            Åpne Analytics ↗
          </a>
        </div>
      </div>

      <hr class="divider" />

      <div class="card">
        <div class="card-title">Instagram – innholdsplan</div>
        <p style="font-size:0.8rem;color:var(--ink-muted);margin-bottom:1rem;">
          Tips for best rekkevidde på Instagram:
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;font-size:0.8rem;">
          <div style="background:var(--bg);border-radius:8px;padding:0.85rem;">
            <div style="font-weight:600;margin-bottom:0.3rem;">🕐 Beste tidspunkter</div>
            <div style="color:var(--ink-muted);line-height:1.6;">
              Tirsdag–fredag 11–13 og 18–21<br>
              Lørdag morgen 09–11
            </div>
          </div>
          <div style="background:var(--bg);border-radius:8px;padding:0.85rem;">
            <div style="font-weight:600;margin-bottom:0.3rem;">📈 Innholdstyper</div>
            <div style="color:var(--ink-muted);line-height:1.6;">
              Reels: best rekkevidde<br>
              Karusell: høy engasjement<br>
              Stories: daglig oppdatering
            </div>
          </div>
          <div style="background:var(--bg);border-radius:8px;padding:0.85rem;">
            <div style="font-weight:600;margin-bottom:0.3rem;">#️⃣ Nøkkel-hashtags</div>
            <div style="color:var(--ink-muted);line-height:1.6;font-size:0.72rem;">
              #seilbåt #sailing #norgeseglareforbundet #kappseiling #livetilsjøs
            </div>
          </div>
          <div style="background:var(--bg);border-radius:8px;padding:0.85rem;">
            <div style="font-weight:600;margin-bottom:0.3rem;">✅ Frekvens</div>
            <div style="color:var(--ink-muted);line-height:1.6;">
              Anbefalt: 3–5 innlegg/uke<br>
              Stories: daglig i sesong
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</div>

<!-- ── Modal: Legg til innlegg ── -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal">
    <div class="modal-title" id="modal-title">Nytt innlegg</div>

    <input type="hidden" id="edit-id" />

    <div class="form-group">
      <label class="form-label">Tittel / tema *</label>
      <input type="text" id="input-title" placeholder="F.eks. Regatta Lysakerfjorden" />
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Plattform</label>
        <select id="input-platform">
          <option value="instagram">📸 Instagram</option>
          <option value="facebook">📘 Facebook</option>
          <option value="nettside">🌐 Nettside</option>
          <option value="annet">📌 Annet</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Status</label>
        <select id="input-status">
          <option value="planlagt">Planlagt</option>
          <option value="skrevet">Skrevet</option>
          <option value="publisert">Publisert</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Publiseringsdato</label>
      <input type="date" id="input-date" />
    </div>

    <div class="form-group">
      <label class="form-label">Notater / bildetekst</label>
      <textarea id="input-notes" rows="3" placeholder="Bildetekst, ideer, hashtags..."></textarea>
    </div>

    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal()">Avbryt</button>
      <button class="btn btn-primary" onclick="saveItem()">Lagre</button>
    </div>
  </div>
</div>

<script>
  // ── State ──────────────────────────────────────────────
  let planItems = JSON.parse(localStorage.getItem('rocky_plan') || '[]');
  let savedIdeas = JSON.parse(localStorage.getItem('rocky_ideas') || '[]');
  let currentFilter = 'alle';
  let selectedTopic = '';
  let lastAiOutput = '';

  // ── Navigation ─────────────────────────────────────────
  function navigate(sectionId) {
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById(sectionId)?.classList.add('active');
    document.querySelector(`.nav-item[data-section="${sectionId}"]`)?.classList.add('active');
  }

  document.querySelectorAll('.nav-item').forEach(item => {
    item.addEventListener('click', () => navigate(item.dataset.section));
  });

  // ── Content plan ───────────────────────────────────────
  const PLATFORM_ICONS = { instagram: '📸', facebook: '📘', nettside: '🌐', annet: '📌' };

  function savePlan() {
    localStorage.setItem('rocky_plan', JSON.stringify(planItems));
    renderPlan();
    updateStats();
    renderOverviewUpcoming();
  }

  function renderPlan() {
    const list = document.getElementById('plan-list');
    const filtered = currentFilter === 'alle'
      ? planItems
      : planItems.filter(i => i.status === currentFilter);

    if (filtered.length === 0) {
      list.innerHTML = '<div class="empty-state"><p>Ingen innlegg funnet.</p></div>';
      return;
    }

    filtered.sort((a, b) => (a.date || '9999') < (b.date || '9999') ? -1 : 1);

    list.innerHTML = filtered.map(item => `
      <div class="plan-item">
        <div class="plan-item-platform">${PLATFORM_ICONS[item.platform] || '📌'}</div>
        <div class="plan-item-body">
          <div class="plan-item-title">${esc(item.title)}</div>
          <div class="plan-item-meta">
            ${item.date ? formatDate(item.date) + ' · ' : ''}
            <span class="badge badge-${item.status}">${item.status}</span>
          </div>
          ${item.notes ? `<div style="font-size:0.72rem;color:var(--ink-muted);margin-top:0.25rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(item.notes)}</div>` : ''}
        </div>
        <div class="plan-item-actions">
          <button class="btn btn-ghost btn-sm" onclick="openEditModal('${item.id}')">✏️</button>
          <button class="btn btn-danger btn-sm" onclick="deleteItem('${item.id}')">🗑</button>
        </div>
      </div>
    `).join('');
  }

  function renderOverviewUpcoming() {
    const el = document.getElementById('oversikt-upcoming');
    const upcoming = planItems
      .filter(i => i.status !== 'publisert')
      .sort((a, b) => (a.date || '9999') < (b.date || '9999') ? -1 : 1)
      .slice(0, 4);

    if (upcoming.length === 0) {
      el.innerHTML = '<div class="empty-state"><p>Ingen innlegg planlagt ennå.<br>Gå til Innholdsplan for å legge til.</p></div>';
      return;
    }

    el.innerHTML = upcoming.map(item => `
      <div class="plan-item">
        <div class="plan-item-platform">${PLATFORM_ICONS[item.platform] || '📌'}</div>
        <div class="plan-item-body">
          <div class="plan-item-title">${esc(item.title)}</div>
          <div class="plan-item-meta">${item.date ? formatDate(item.date) + ' · ' : ''}<span class="badge badge-${item.status}">${item.status}</span></div>
        </div>
      </div>
    `).join('');
  }

  function updateStats() {
    document.getElementById('stat-planlagt').textContent =
      planItems.filter(i => i.status === 'planlagt').length;
    document.getElementById('stat-publisert').textContent =
      planItems.filter(i => i.status === 'publisert').length;
    document.getElementById('stat-ideer').textContent = savedIdeas.length;
  }

  function openAddModal() {
    document.getElementById('modal-title').textContent = 'Nytt innlegg';
    document.getElementById('edit-id').value = '';
    document.getElementById('input-title').value = '';
    document.getElementById('input-platform').value = 'instagram';
    document.getElementById('input-status').value = 'planlagt';
    document.getElementById('input-date').value = '';
    document.getElementById('input-notes').value = '';
    document.getElementById('modal-overlay').classList.add('open');
  }

  function openEditModal(id) {
    const item = planItems.find(i => i.id === id);
    if (!item) return;
    document.getElementById('modal-title').textContent = 'Rediger innlegg';
    document.getElementById('edit-id').value = id;
    document.getElementById('input-title').value = item.title;
    document.getElementById('input-platform').value = item.platform;
    document.getElementById('input-status').value = item.status;
    document.getElementById('input-date').value = item.date || '';
    document.getElementById('input-notes').value = item.notes || '';
    document.getElementById('modal-overlay').classList.add('open');
  }

  function closeModal() {
    document.getElementById('modal-overlay').classList.remove('open');
  }

  function saveItem() {
    const title = document.getElementById('input-title').value.trim();
    if (!title) { alert('Skriv inn en tittel'); return; }

    const id = document.getElementById('edit-id').value;
    const item = {
      id: id || crypto.randomUUID(),
      title,
      platform: document.getElementById('input-platform').value,
      status: document.getElementById('input-status').value,
      date: document.getElementById('input-date').value,
      notes: document.getElementById('input-notes').value.trim(),
      createdAt: id ? undefined : new Date().toISOString(),
    };

    if (id) {
      const idx = planItems.findIndex(i => i.id === id);
      if (idx !== -1) {
        item.createdAt = planItems[idx].createdAt;
        planItems[idx] = item;
      }
    } else {
      planItems.push(item);
    }

    savePlan();
    closeModal();
  }

  function deleteItem(id) {
    if (!confirm('Slett dette innlegget?')) return;
    planItems = planItems.filter(i => i.id !== id);
    savePlan();
  }

  // Filter tabs
  document.querySelectorAll('.filter-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentFilter = tab.dataset.filter;
      renderPlan();
    });
  });

  // Close modal on overlay click
  document.getElementById('modal-overlay').addEventListener('click', e => {
    if (e.target === e.currentTarget) closeModal();
  });

  // ── AI Assistent ───────────────────────────────────────
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
      if (selectedTopic === chip.dataset.topic) {
        selectedTopic = '';
      } else {
        chip.classList.add('selected');
        selectedTopic = chip.dataset.topic;
      }
    });
  });

  async function generateIdeas() {
    const customTopic = document.getElementById('custom-topic').value.trim();
    const topic = customTopic || selectedTopic;

    if (!topic) {
      alert('Velg et tema eller skriv inn et eget tema');
      return;
    }

    const extra = document.getElementById('extra-context').value.trim();
    const btn = document.getElementById('generate-btn');
    const output = document.getElementById('ai-output');
    const saveBtn = document.getElementById('save-ideas-btn');

    btn.disabled = true;
    btn.textContent = '⏳ Genererer...';
    output.className = 'ai-output loading';
    output.textContent = 'Claude tenker...';
    saveBtn.style.display = 'none';
    lastAiOutput = '';

    try {
      const res = await fetch('/api/ideas', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ topic, extra }),
      });

      if (!res.ok) {
        const text = await res.text();
        throw new Error(text || res.statusText);
      }

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      output.className = 'ai-output';
      output.textContent = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        lastAiOutput += decoder.decode(value, { stream: true });
        output.textContent = lastAiOutput;
        output.scrollTop = output.scrollHeight;
      }

      saveBtn.style.display = lastAiOutput ? 'inline-flex' : 'none';
    } catch (err) {
      output.className = 'ai-output';
      output.textContent = '❌ Feil: ' + err.message;
    } finally {
      btn.disabled = false;
      btn.textContent = '✨ Generer ideer';
    }
  }

  function saveIdeasToPlan() {
    if (!lastAiOutput) return;

    // Parse and save each idea block as a plan item
    const blocks = lastAiOutput.split(/\*\*Innlegg \d+:/).filter(Boolean);
    const customTopic = document.getElementById('custom-topic').value.trim();
    const topic = customTopic || selectedTopic;

    if (blocks.length > 0) {
      blocks.forEach((block, i) => {
        const title = block.split('\n')[0].replace(/\*\*/g, '').trim();
        planItems.push({
          id: crypto.randomUUID(),
          title: title || `Idé ${i + 1}: ${topic}`,
          platform: 'instagram',
          status: 'planlagt',
          date: '',
          notes: block.trim().replace(/\*\*/g, ''),
          createdAt: new Date().toISOString(),
        });
      });
    } else {
      savedIdeas.push({
        id: crypto.randomUUID(),
        topic,
        content: lastAiOutput,
        savedAt: new Date().toISOString(),
      });
      localStorage.setItem('rocky_ideas', JSON.stringify(savedIdeas));
    }

    savePlan();
    alert(`${blocks.length || 1} idé(er) lagret i innholdsplanen!`);
    navigate('innholdsplan');
  }

  // ── Helpers ────────────────────────────────────────────
  function esc(str) {
    return String(str ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function formatDate(dateStr) {
    if (!dateStr) return '';
    const d = new Date(dateStr + 'T12:00:00');
    return d.toLocaleDateString('no-NO', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  // ── Init ───────────────────────────────────────────────
  renderPlan();
  updateStats();
  renderOverviewUpcoming();
</script>
</body>
</html>
