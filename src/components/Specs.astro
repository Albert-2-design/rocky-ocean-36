---
const specs = [
  { label: 'LOA',           value: '11.100 m' },
  { label: 'Beam',          value: '3.470 m' },
  { label: 'Draft',         value: '2.117 m' },
  { label: 'Displacement',  value: '7 295 kg' },
  { label: 'Year built',    value: '2005' },
  { label: 'Class',         value: 'One-off' },
  { label: 'Type',          value: 'Cruiser / Racer' },
  { label: 'Designer',      value: 'H. Aaslestad' },
  { label: 'GPH',           value: '657.5' },
  { label: 'CDL',           value: '9.052' },
  { label: 'Sail number',   value: 'NOR 11782' },
  { label: 'ORC Ref',       value: '03440002I62' },
  { label: 'Certificate',   value: 'ORC Club Non-Spinnaker 2023' },
  { label: 'Federation',    value: 'Norwegian Sailing Federation' },
];
---

<section id="spesifikasjoner" class="specs">
  <div class="container">

    <div class="specs-header">
      <p class="section-label">Specifications</p>
      <h2 class="display specs-title">Key Figures</h2>
    </div>

    <dl class="specs-grid">
      {specs.map(({ label, value }) => (
        <div class="spec-item">
          <dt>{label}</dt>
          <dd>{value}</dd>
        </div>
      ))}
    </dl>

    <div class="specs-cta">
      <a href="/orc-certificate.html" target="_blank" rel="noopener" class="cert-link">
        View full ORC certificate
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .specs {
    padding: var(--section-pad);
    background: #F2F2EE;
  }

  .specs-header {
    margin-bottom: 4rem;
  }

  .section-label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
    font-weight: 400;
  }

  .specs-title {
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    color: var(--ink);
    line-height: 1.0;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .specs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    border-top: 1px solid var(--border);
  }

  .spec-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-right: 2rem;
  }

  dt {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 400;
  }

  dd {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: 0.01em;
  }

  .specs-cta {
    margin-top: 3.5rem;
  }

  .cert-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 0.2rem;
    transition: color 0.2s, border-color 0.2s;
  }

  .cert-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 640px) {
    .specs-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
